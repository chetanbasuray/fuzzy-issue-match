{
  "name": "fuzzy-issue-match",
  "version": "0.0.0",
  "description": "Detect potential duplicate GitHub issues using fuzzy and semantic similarity.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "release": "semantic-release"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chetanbasuray/fuzzy-issue-match.git"
  },
  "homepage": "https://github.com/chetanbasuray/fuzzy-issue-match#readme",
  "bugs": {
    "url": "https://github.com/chetanbasuray/fuzzy-issue-match/issues"
  },
  "keywords": [
    "github",
    "github-action",
    "issue-triage",
    "duplicate-issues",
    "levenshtein",
    "semantic-similarity",
    "triage-automation",
    "maintainer-tools",
    "issue-deduplication",
    "typescript",
    "npm"
  ],
  "license": "MIT",
  "author": "Chetan Basuray",
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.25.0",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/node": "^22.14.1",
    "eslint": "^9.25.1",
    "globals": "^16.0.0",
    "semantic-release": "^25.0.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vitest": "^3.1.2"
  }
}
